# AI Provider Keys (Server-side)
# Get these from your Google AI and OpenAI dashboards.
GEMINI_API_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"

# MAGNUS AI Configuration (Server-side)
# The OpenAI model to be used by the MAGNUS prompt.
MAGNUS_OPENAI_MODEL="gpt-4o-mini"

# n8n Webhook Secret (Server-side)
# A strong, randomly generated secret token to secure your n8n webhook.
# This value must be used as a Bearer token in your n8n workflow's HTTP Request node.
N8N_SECRET_TOKEN="your-strong-random-secret"

# Next.js Server Configuration
# The port your Next.js app will run on inside the Docker container.
PORT=3000
